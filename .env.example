# ===============================
# DATABASE
# ===============================
# PostgreSQL connection string from Neon.tech
# Format: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/dropshipping?sslmode=require"

# ===============================
# NEXTAUTH
# ===============================
# Generate with: openssl rand -base64 64
NEXTAUTH_SECRET="your-64-char-random-secret-key-generate-with-openssl-rand-base64-64"

# Production: https://yourdomain.com | Development: http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"

# ===============================
# CLOUDINARY (Image & File Uploads)
# ===============================
# Get from Cloudinary Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_PRESET="dropshipping"

# ===============================
# STRIPE (Primary Payment Gateway)
# ===============================
# Get from Stripe Dashboard > Developers > API Keys
# Use test keys for development (sk_test_ and pk_test_)
STRIPE_PUBLISHABLE_KEY="pk_test_your-publishable-key"
STRIPE_SECRET_KEY="sk_test_your-secret-key"
# Webhook signing secret from Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# ===============================
# JAZZCASH (Pakistan Mobile Wallet)
# ===============================
# Get from JazzCash Merchant Portal
JAZZCASH_MERCHANT_ID="your-merchant-id"
JAZZCASH_PASSWORD="your-password"
JAZZCASH_INTEGRITY_SALT="your-integrity-salt"
JAZZCASH_SANDBOX="true"
# Production URL: https://payments.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform
JAZZCASH_API_URL="https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform"

# ===============================
# EASYPAISA (Pakistan Mobile Wallet)
# ===============================
# Get from Easypaisa Merchant Support
EASYPAISA_STORE_ID="your-store-id"
EASYPAISA_HASH_KEY="your-hash-key"
EASYPAISA_SANDBOX="true"
# Production URL: https://easypay.easypaisa.com.pk/tpg
EASYPAISA_API_URL="https://easypaystg.easypaisa.com.pk/tpg"

# ===============================
# PAYPAL
# ===============================
# Get from PayPal Developer Dashboard
PAYPAL_CLIENT_ID="your-client-id"
PAYPAL_SECRET="your-secret"
PAYPAL_SANDBOX="true"

# ===============================
# PUSHER (Real-time Features)
# ===============================
# Get from Pusher Dashboard > App Keys
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-key"
PUSHER_SECRET="your-secret"
PUSHER_CLUSTER="ap2"
# Client-side key (same as PUSHER_KEY)
NEXT_PUBLIC_PUSHER_KEY="your-key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# ===============================
# RESEND (Transactional Email)
# ===============================
# Get from Resend Dashboard > API Keys
RESEND_API_KEY="re_your-api-key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_FROM_NAME="Your Store Name"

# ===============================
# GOOGLE OAUTH (Social Login)
# ===============================
# Get from Google Cloud Console > APIs > Credentials
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# ===============================
# GOOGLE MAPS (Address Autocomplete)
# ===============================
GOOGLE_MAPS_API_KEY="your-maps-api-key"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-maps-api-key"

# ===============================
# UPSTASH (Rate Limiting)
# ===============================
# Get from Upstash Console > Redis Database
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ===============================
# TWILIO (SMS - Optional)
# ===============================
# Get from Twilio Console
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# ===============================
# ENCRYPTION
# ===============================
# Generate with: openssl rand -hex 32
# Used for encrypting sensitive data like bank details
ENCRYPTION_KEY="your-64-char-hex-key-generate-with-openssl-rand-hex-32"
ENCRYPTION_IV="your-32-char-hex-iv"

# ===============================
# RECAPTCHA (Bot Protection)
# ===============================
# Get from Google reCAPTCHA Admin Console
RECAPTCHA_SITE_KEY="your-site-key"
RECAPTCHA_SECRET_KEY="your-secret-key"
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-site-key"

# ===============================
# ANALYTICS (Optional)
# ===============================
GOOGLE_ANALYTICS_ID="G-XXXXXXXXXX"
FACEBOOK_PIXEL_ID="your-pixel-id"
GTM_ID="GTM-XXXXXX"

# ===============================
# SITE CONFIG
# ===============================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Vynate Market"
NEXT_PUBLIC_DEFAULT_CURRENCY="USD"

# ===============================
# CRON SECRETS
# ===============================
# Used to secure cron API endpoints
CRON_SECRET="your-cron-secret-key"

# ===============================
# NODE ENVIRONMENT
# ===============================
NODE_ENV="development"
